#!/usr/bin/env bash
# sl-pull-logs — rolling rsync mirror of the Pi's /var/log/pi-monitor/ to a
# laptop-side directory (default: stm-32-firmware/serial_monitor_outputs/).
# Sibling to sl-transfer-log; this one is the rolling-mirror variant for
# always-current LLM-assisted log analysis (see docs/plans/2026-05-10-sl-debug-revised-plan.md).
set -euo pipefail

HOST=${HOST:-dev@pi-monitor}
DEST=${SL_LOG_DEST:-$HOME/Desktop/smartLock/stm-32-firmware/serial_monitor_outputs}
REMOTE_DIR=/var/log/pi-monitor
DRY_RUN=0

usage() {
  cat >&2 <<EOF
Usage: sl-pull-logs [--host <user@host>] [--dry-run] [<dest-dir>]

Rolling rsync mirror of \$HOST:$REMOTE_DIR/ → <dest-dir>. Each run keeps
the destination in sync with the Pi (uses --delete) and excludes findings.md
so the append-only finding store is never touched.

Default destination: $DEST
Override with: positional <dest-dir>, or env var SL_LOG_DEST.

Options:
  --host <user@host>   SSH target (default: $HOST; override via \$HOST too)
  --dry-run            Print the rsync command without running it
  -h, --help           Show this help

Examples:
  sl-pull-logs                                            # default dest
  sl-pull-logs ~/some/other/dir                           # override dest
  sl-pull-logs --host patrik@pi-monitor.local             # override host

Prereqs:
  - ssh \$HOST must succeed non-interactively (key auth or Tailscale SSH).
  - Reuses your ~/.ssh/config (ControlMaster, etc.) automatically.
EOF
}

while [ $# -gt 0 ]; do
  case $1 in
    --host)
      [ $# -ge 2 ] || { echo "sl-pull-logs: --host needs an argument" >&2; exit 2; }
      HOST=$2; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*) echo "sl-pull-logs: unknown flag: $1" >&2; usage; exit 2 ;;
    *) break ;;
  esac
done

if [ $# -ge 1 ]; then
  DEST=$1; shift
fi
if [ $# -ne 0 ]; then
  echo "sl-pull-logs: too many positional arguments" >&2
  usage; exit 2
fi

CMD=(rsync -av --delete --exclude=findings.md
     -e "ssh -o BatchMode=yes"
     "$HOST:$REMOTE_DIR/" "$DEST/")

if [ "$DRY_RUN" = "1" ]; then
  # Use %q so the printed line is copy-paste-safe (preserves the quoted
  # `-e "ssh -o BatchMode=yes"` group; plain ${CMD[*]} loses the quotes).
  printf '%q ' "${CMD[@]}"
  printf '\n'
  exit 0
fi

mkdir -p "$DEST"
echo "Mirroring $HOST:$REMOTE_DIR/ → $DEST/"
"${CMD[@]}"

count=$(find "$DEST" -type f ! -name 'findings.md' 2>/dev/null | wc -l | tr -d ' ')
size=$(du -sh "$DEST" 2>/dev/null | awk '{print $1}')
echo
echo "Done — $count log files, $size in $DEST"
